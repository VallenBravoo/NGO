# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Get this from your Neon dashboard
DATABASE_URL="postgresql://user:password@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth Secret
# You can generate a new secret on the command line with:
# openssl rand -base64 32
# or use `npx auth secret`
AUTH_SECRET="your-super-secret-auth-key-change-in-production"

# Stripe Keys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Site URL for callbacks and webhooks
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
